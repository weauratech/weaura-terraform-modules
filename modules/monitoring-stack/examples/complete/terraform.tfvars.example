# ============================================================
# Example Terraform Variables
# ============================================================
# Copy this file to terraform.tfvars and fill in your values
# ============================================================

# --------------------------------
# Required Variables
# --------------------------------

tenant_id    = "acme-corp"
tenant_name  = "ACME Corporation"

eks_cluster_name      = "my-eks-cluster"
eks_oidc_provider_arn = "arn:aws:iam::123456789012:oidc-provider/oidc.eks.us-east-1.amazonaws.com/id/EXAMPLE"
eks_oidc_provider_url = "oidc.eks.us-east-1.amazonaws.com/id/EXAMPLE"

grafana_domain           = "grafana.example.com"
monitoring_chart_version = "0.1.10"

# IMPORTANT: Use a secure password or reference AWS Secrets Manager
grafana_admin_password = "change-me-to-secure-password"

# --------------------------------
# Optional Variables
# --------------------------------

aws_region  = "us-east-1"
environment = "production"

# Harbor OCI auth (provided by WeAura)
# harbor_username = ""
# harbor_password = ""
